#!/usr/bin/env bash
set -euo pipefail

# Valid conventional commit types.
valid_types="feat fix refactor docs test chore perf ci build style revert"

# Model used by the fast direct Copilot API path. Override with GAI_MODEL.
: "${GAI_MODEL:=gpt-4o-mini}"
: "${GAI_CLI_FALLBACK:=0}"
GAI_LAST_ERROR=""

if ! command git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Not inside a git repository."
  exit 1
fi

if command git diff --cached --quiet; then
  echo "No staged changes."
  exit 1
fi

commit_type="${1:-}"

if [ -n "$commit_type" ]; then
  if ! printf "%s" " $valid_types " | grep -q " $commit_type "; then
    echo "Invalid commit type: $commit_type"
    echo "Valid types: $valid_types"
    exit 1
  fi
fi

staged_names="$(command git diff --cached --name-status --no-color)"
staged_stat="$(command git diff --cached --stat --no-color)"

full_diff="$(command git diff --cached --no-color)"
if [ "${#full_diff}" -gt 2000 ]; then
  staged_diff="${full_diff:0:2000}
... (diff truncated)"
else
  staged_diff="$full_diff"
fi

type_hint=""
if [ -n "$commit_type" ]; then
  type_hint="
IMPORTANT: The commit type MUST be \"${commit_type}\". Use exactly: ${commit_type}(scope?): subject"
fi

copilot_token_cache="${TMPDIR:-/tmp}/gai-copilot-token-$(id -u).json"

_gai_oauth_token() {
  local apps oauth

  if [ -n "${GITHUB_COPILOT_TOKEN:-}" ]; then
    printf '%s\n' "$GITHUB_COPILOT_TOKEN"
    return 0
  fi

  if [ -n "${GH_COPILOT_TOKEN:-}" ]; then
    printf '%s\n' "$GH_COPILOT_TOKEN"
    return 0
  fi

  apps="$HOME/.config/github-copilot/apps.json"
  if [ -f "$apps" ]; then
    oauth="$(jq -r '[..|.oauth_token? // empty] | .[0] // empty' "$apps" 2>/dev/null || true)"
    if [ -n "$oauth" ]; then
      printf '%s\n' "$oauth"
      return 0
    fi
  fi

  command -v gh >/dev/null 2>&1 || return 1
  gh auth status >/dev/null 2>&1 || return 1
  gh auth token 2>/dev/null
}

_gai_copilot_token() {
  command -v jq >/dev/null 2>&1 || return 1
  command -v curl >/dev/null 2>&1 || return 1

  local now exp tok api oauth resp
  now="$(date +%s)"

  if [ -f "$copilot_token_cache" ]; then
    exp="$(jq -r '.expires_at // 0' "$copilot_token_cache" 2>/dev/null || echo 0)"
    if [ "${exp:-0}" -gt "$((now + 60))" ] 2>/dev/null; then
      tok="$(jq -r '.token // empty' "$copilot_token_cache" 2>/dev/null || true)"
      api="$(jq -r '.endpoints.api // empty' "$copilot_token_cache" 2>/dev/null || true)"
      if [ -n "$tok" ] && [ -n "$api" ]; then
        printf '%s\t%s\n' "$tok" "$api"
        return 0
      fi
    fi
  fi

  oauth="$(_gai_oauth_token)" || return 1
  [ -n "$oauth" ] || return 1

  resp="$(curl -sS --max-time 10 \
    -H "Authorization: token $oauth" \
    https://api.github.com/copilot_internal/v2/token 2>/dev/null || true)"
  tok="$(printf '%s' "$resp" | jq -r '.token // empty' 2>/dev/null || true)"
  api="$(printf '%s' "$resp" | jq -r '.endpoints.api // empty' 2>/dev/null || true)"
  [ -n "$tok" ] && [ -n "$api" ] || return 1

  printf '%s' "$resp" >"$copilot_token_cache" 2>/dev/null || true
  chmod 600 "$copilot_token_cache" 2>/dev/null || true
  printf '%s\t%s\n' "$tok" "$api"
}

_gai_via_api() {
  local prompt="$1"
  local creds tok api body out content
  creds="$(_gai_copilot_token)" || return 1
  tok="${creds%%	*}"
  api="${creds#*	}"
  [ -n "$tok" ] && [ -n "$api" ] || return 1

  body="$(jq -n --arg m "$GAI_MODEL" --arg c "$prompt" \
    '{model:$m,temperature:0,max_tokens:40,messages:[{role:"user",content:$c}]}')"

  out="$(curl -sS --max-time 30 "$api/chat/completions" \
    -H "Authorization: Bearer $tok" \
    -H "Content-Type: application/json" \
    -H "Copilot-Integration-Id: vscode-chat" \
    -H "Editor-Version: vscode/1.0.0" \
    -d "$body" 2>/dev/null || true)"

  content="$(printf '%s' "$out" | jq -r '.choices[0].message.content // empty' 2>/dev/null || true)"
  [ -n "$content" ] || return 1
  printf '%s\n' "$content"
}

_gai_via_cli() {
  local prompt="$1"
  local cli="$HOME/.local/share/gh/copilot/copilot"

  if [ -x "$cli" ]; then
    "$cli" -s -p "$prompt"
  else
    gh copilot -- -s -p "$prompt"
  fi
}

generate_msg() {
  local prompt raw err_file status
  prompt="$(
    cat <<PROMPT
Output MUST be exactly ONE line and NOTHING ELSE.

Write a Conventional Commits SUBJECT line for the staged changes.

Hard rules:
- Format: type(scope?): subject
- type must be one of: $valid_types
- subject length <= 72 characters
- No preamble, no questions, no quotes, no markdown, no bullets, no stats/cost/model info.
${type_hint}

Staged files:
${staged_names}

Diffstat:
${staged_stat}

Diff:
${staged_diff}
PROMPT
  )"

  echo "Generating commit message..." >&2

  GAI_LAST_ERROR=""
  raw="$(_gai_via_api "$prompt" 2>/dev/null || true)"
  if [ -z "$raw" ]; then
    if [ "$GAI_CLI_FALLBACK" = "1" ]; then
      err_file="$(mktemp)" || return 1
      set +e
      raw="$(_gai_via_cli "$prompt" 2>"$err_file")"
      status="$?"
      set -e
      if [ "$status" -ne 0 ] || [ -z "$raw" ]; then
        GAI_LAST_ERROR="$(awk 'NF {print}' "$err_file" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//' | head -n 6)"
      fi
      rm -f "$err_file"
    else
      GAI_LAST_ERROR="Fast Copilot token unavailable. Run :Copilot auth in Neovim, or set GITHUB_COPILOT_TOKEN/GH_COPILOT_TOKEN from :Copilot auth info. Set GAI_CLI_FALLBACK=1 to allow the slow Copilot CLI fallback."
    fi
  fi

  printf "%s\n" "$raw" |
    awk 'NF {print; exit}' |
    sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//; s/^["'\''`]+//; s/["'\''`]+$//'
}

edit_msg() {
  local current="$1"
  local edited
  printf "Edit message: "
  if read -r -e -i "$current" edited 2>/dev/null; then
    msg="$edited"
  else
    printf "Edit message [%s]: " "$current"
    read -r edited
    msg="${edited:-$current}"
  fi
}

worktree_has_uncommitted_changes() {
  [ -n "$(command git status --porcelain --untracked-files=normal)" ]
}

find_lazygit_ancestor() {
  local pid command_name parent_pid
  pid="$PPID"

  while [ -n "$pid" ] && [ "$pid" -gt 1 ] 2>/dev/null; do
    command_name="$(ps -o comm= -p "$pid" 2>/dev/null || true)"
    command_name="${command_name##*/}"
    if [ "$command_name" = "lazygit" ]; then
      printf '%s\n' "$pid"
      return 0
    fi

    parent_pid="$(ps -o ppid= -p "$pid" 2>/dev/null || true)"
    parent_pid="${parent_pid//[[:space:]]/}"
    [ "$parent_pid" != "$pid" ] || break
    pid="$parent_pid"
  done

  return 1
}

exit_lazygit_if_worktree_clean() {
  local lazygit_pid

  [ "${GAI_EXIT_LAZYGIT_IF_CLEAN:-0}" = "1" ] || return 0
  worktree_has_uncommitted_changes && return 0

  lazygit_pid="$(find_lazygit_ancestor)" || return 0
  kill -TERM "$lazygit_pid" 2>/dev/null || true
}

print_auth_hint() {
  if [ -n "$GAI_LAST_ERROR" ]; then
    echo "Copilot error:"
    printf "%s\n" "$GAI_LAST_ERROR" | sed 's/^/  /'
    echo
  fi

  if [ ! -f "$HOME/.config/github-copilot/apps.json" ] && ! gh auth status >/dev/null 2>&1; then
    echo "No Copilot auth found."
    echo "Either sign in to Copilot.nvim so ~/.config/github-copilot/apps.json exists,"
    echo "or run gh auth login and make sure GitHub Copilot CLI can run."
    echo
  fi
}

msg="$(generate_msg)"

while true; do
  if [ -z "$msg" ]; then
    echo "Copilot returned an empty response."
    print_auth_hint
    echo
    printf "  [r]etry  [m]anual  [q]uit: "
    read -r choice
    case "${choice:-q}" in
      r | R | retry)
        msg="$(generate_msg)"
        continue
        ;;
      m | M | manual)
        printf "Enter commit subject: "
        read -r msg
        msg="$(printf "%s\n" "$msg" | awk 'NF {print; exit}')"
        [ -z "$msg" ] && echo "Cancelled." && exit 0
        continue
        ;;
      *)
        echo "Cancelled."
        exit 0
        ;;
    esac
  fi

  if ! printf "%s\n" "$msg" | grep -Eq '^(feat|fix|refactor|docs|test|chore|perf|ci|build|style|revert)(\([^)]+\))?: .+$'; then
    echo "Copilot output does not look like a conventional commit subject:"
    printf "  %s\n" "$msg" >&2
    echo
    printf "  [r]etry  [e]dit  [m]anual  [q]uit: "
    read -r choice
    case "${choice:-q}" in
      r | R | retry)
        msg="$(generate_msg)"
        continue
        ;;
      e | E | edit)
        edit_msg "$msg"
        continue
        ;;
      m | M | manual)
        printf "Enter commit subject: "
        read -r msg
        msg="$(printf "%s\n" "$msg" | awk 'NF {print; exit}')"
        [ -z "$msg" ] && echo "Cancelled." && exit 0
        continue
        ;;
      *)
        echo "Cancelled."
        exit 0
        ;;
    esac
  fi

  echo
  echo "Proposed commit subject:"
  echo "  $msg"
  echo

  read -r -p "[Y]es  [n]o  [e]dit  [r]etry? " ans
  case "${ans:-Y}" in
    Y | y | yes | YES)
      command git commit -m "$msg"
      exit_lazygit_if_worktree_clean
      break
      ;;
    e | E | edit)
      edit_msg "$msg"
      continue
      ;;
    r | R | retry)
      msg="$(generate_msg)"
      continue
      ;;
    *)
      echo "Cancelled."
      exit 0
      ;;
  esac
done
