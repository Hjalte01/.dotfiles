#!/usr/bin/env bash
set -euo pipefail

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
persist_dir="${XDG_STATE_HOME:-$HOME/.local/state}/autoscroll"
state_dir="$runtime_dir/autoscroll"
armed_file="$state_dir/z-armed"
pid_file="$state_dir/autoscroll.pid"
direction_file="$state_dir/direction"
speed_file="$persist_dir/scrolls-per-second"
socket_path="/run/ydotoold/socket"
script_path="$HOME/.local/bin/autoscroll"
default_speed="6"
down_key="${AUTOSCROLL_KEY:-108}"
up_key="${AUTOSCROLL_UP_KEY:-103}"

mkdir -p "$state_dir"
mkdir -p "$persist_dir"

notify() {
  notify-send "Autoscroll" "$1" 2>/dev/null || true
}

read_speed() {
  local speed="$default_speed"
  if [[ -f "$speed_file" ]]; then
    IFS= read -r speed < "$speed_file" || speed="$default_speed"
  fi

  if [[ ! "$speed" =~ ^[0-9]+$ || "$speed" -lt 1 ]]; then
    speed="$default_speed"
  fi

  printf '%s\n' "$speed"
}

write_speed() {
  printf '%s\n' "$1" > "$speed_file"
}

scroll_delay() {
  awk -v speed="$(read_speed)" 'BEGIN { printf "%.6f\n", 1 / speed }'
}

is_scrolling() {
  [[ -f "$pid_file" ]] || return 1
  local pid
  IFS= read -r pid < "$pid_file" || return 1
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

stop_scrolling() {
  if is_scrolling; then
    local pid
    IFS= read -r pid < "$pid_file"
    kill "$pid" 2>/dev/null || true
  fi
  rm -f "$pid_file"
  rm -f "$direction_file"
}

start_scrolling() {
  local direction="${1:-down}"
  local key="$down_key"
  if [[ "$direction" == "up" ]]; then
    key="$up_key"
  else
    direction="down"
  fi

  if ! command -v ydotool >/dev/null 2>&1; then
    notify "ydotool is not installed. Rebuild Home Manager first."
    exit 1
  fi

  if [[ ! -S "$socket_path" ]]; then
    notify "ydotoold is not running. Rebuild NixOS and restart first."
    exit 1
  fi

  (
    export YDOTOOL_SOCKET="$socket_path"
    scroll_delay="$(scroll_delay)"
    while true; do
      ydotool key "${key}:1" "${key}:0" >/dev/null 2>&1 || exit 1
      sleep "$scroll_delay"
    done
  ) &

  printf '%s\n' "$!" > "$pid_file"
  printf '%s\n' "$direction" > "$direction_file"
}

current_direction() {
  local direction="down"
  if [[ -f "$direction_file" ]]; then
    IFS= read -r direction < "$direction_file" || direction="down"
  fi

  if [[ "$direction" != "up" ]]; then
    direction="down"
  fi

  printf '%s\n' "$direction"
}

toggle_scrolling() {
  local direction="${1:-down}"
  if [[ "$direction" != "up" ]]; then
    direction="down"
  fi

  if is_scrolling && [[ "$(current_direction)" == "$direction" ]]; then
    stop_scrolling
    notify "stopped"
  else
    stop_scrolling
    start_scrolling "$direction"
    notify "started ${direction}"
  fi
}

arm_z() {
  if [[ -x "$HOME/.local/bin/autoclicker" ]]; then
    "$HOME/.local/bin/autoclicker" off >/dev/null 2>&1 || true
  fi

  hyprctl keyword bind ", z, exec, $script_path toggle" >/dev/null
  hyprctl keyword bind ", a, exec, $script_path toggle-up" >/dev/null
  hyprctl keyword bind ", plus, exec, $script_path speed-up 1" >/dev/null
  hyprctl keyword bind "CTRL, plus, exec, $script_path speed-up 3" >/dev/null
  hyprctl keyword bind "SHIFT, plus, exec, $script_path speed-up 10" >/dev/null
  hyprctl keyword bind ", minus, exec, $script_path speed-down 1" >/dev/null
  hyprctl keyword bind "CTRL, minus, exec, $script_path speed-down 3" >/dev/null
  hyprctl keyword bind "SHIFT, minus, exec, $script_path speed-down 10" >/dev/null
  : > "$armed_file"
  notify "z scrolls down, a scrolls up, +/- changes speed ($(read_speed)/s)"
}

disarm_z() {
  local notify_mode="${1:-always}"
  local was_scrolling=0
  if is_scrolling; then
    was_scrolling=1
  fi

  stop_scrolling
  hyprctl keyword unbind ", z" >/dev/null || true
  hyprctl keyword unbind ", a" >/dev/null || true
  hyprctl keyword unbind ", plus" >/dev/null || true
  hyprctl keyword unbind "CTRL, plus" >/dev/null || true
  hyprctl keyword unbind "SHIFT, plus" >/dev/null || true
  hyprctl keyword unbind ", minus" >/dev/null || true
  hyprctl keyword unbind "CTRL, minus" >/dev/null || true
  hyprctl keyword unbind "SHIFT, minus" >/dev/null || true
  rm -f "$armed_file"

  if [[ "$notify_mode" == "always" || "$was_scrolling" == "1" ]]; then
    notify "z is normal again"
  fi
}

speed_up() {
  local amount="${1:-1}"
  if [[ ! "$amount" =~ ^[0-9]+$ || "$amount" -lt 1 ]]; then
    amount="1"
  fi

  local speed
  speed="$(read_speed)"
  speed=$((speed + amount))
  write_speed "$speed"

  if is_scrolling; then
    local direction
    direction="$(current_direction)"
    stop_scrolling
    start_scrolling "$direction"
  fi

  notify "${speed} scrolls/s"
}

speed_down() {
  local amount="${1:-1}"
  if [[ ! "$amount" =~ ^[0-9]+$ || "$amount" -lt 1 ]]; then
    amount="1"
  fi

  local speed
  speed="$(read_speed)"
  speed=$((speed - amount))
  if (( speed < 1 )); then
    speed=1
  fi
  write_speed "$speed"

  if is_scrolling; then
    local direction
    direction="$(current_direction)"
    stop_scrolling
    start_scrolling "$direction"
  fi

  notify "${speed} scrolls/s"
}

case "${1:-toggle}" in
  arm-toggle)
    if [[ -f "$armed_file" ]]; then
      disarm_z
    else
      arm_z
    fi
    ;;
  toggle)
    toggle_scrolling down
    ;;
  toggle-up)
    toggle_scrolling up
    ;;
  on)
    if ! is_scrolling; then
      start_scrolling down
      notify "started"
    fi
    ;;
  off)
    disarm_z active
    ;;
  speed-up)
    speed_up "${2:-1}"
    ;;
  speed-down)
    speed_down "${2:-1}"
    ;;
  *)
    printf 'Usage: %s {arm-toggle|toggle|toggle-up|on|off|speed-up AMOUNT|speed-down AMOUNT}\n' "${0##*/}" >&2
    exit 2
    ;;
esac
