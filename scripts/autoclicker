#!/usr/bin/env bash
set -euo pipefail

runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
persist_dir="${XDG_STATE_HOME:-$HOME/.local/state}/autoclicker"
state_dir="$runtime_dir/autoclicker"
armed_file="$state_dir/z-armed"
pid_file="$state_dir/clicker.pid"
speed_file="$persist_dir/clicks-per-second"
socket_path="/run/ydotoold/socket"
script_path="$HOME/.local/bin/autoclicker"
default_speed="12"

mkdir -p "$state_dir"
mkdir -p "$persist_dir"

notify() {
  notify-send "Autoclicker" "$1" 2>/dev/null || true
}

read_speed() {
  local speed="$default_speed"
  if [[ -f "$speed_file" ]]; then
    IFS= read -r speed < "$speed_file" || speed="$default_speed"
  fi

  if [[ ! "$speed" =~ ^[0-9]+$ || "$speed" -lt 1 ]]; then
    speed="$default_speed"
  fi

  printf '%s\n' "$speed"
}

write_speed() {
  printf '%s\n' "$1" > "$speed_file"
}

click_delay() {
  awk -v speed="$(read_speed)" 'BEGIN { printf "%.6f\n", 1 / speed }'
}

is_clicking() {
  [[ -f "$pid_file" ]] || return 1
  local pid
  IFS= read -r pid < "$pid_file" || return 1
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

stop_clicking() {
  if is_clicking; then
    local pid
    IFS= read -r pid < "$pid_file"
    kill "$pid" 2>/dev/null || true
  fi
  rm -f "$pid_file"
}

start_clicking() {
  if ! command -v ydotool >/dev/null 2>&1; then
    notify "ydotool is not installed. Rebuild Home Manager first."
    exit 1
  fi

  if [[ ! -S "$socket_path" ]]; then
    notify "ydotoold is not running. Rebuild NixOS and restart first."
    exit 1
  fi

  (
    export YDOTOOL_SOCKET="$socket_path"
    click_delay="$(click_delay)"
    while true; do
      ydotool click 0xC0 >/dev/null 2>&1 || exit 1
      sleep "$click_delay"
    done
  ) &

  printf '%s\n' "$!" > "$pid_file"
}

arm_z() {
  if [[ -x "$HOME/.local/bin/autoscroll" ]]; then
    "$HOME/.local/bin/autoscroll" off >/dev/null 2>&1 || true
  fi

  if [[ -x "$HOME/.local/bin/cursor-circle" ]]; then
    "$HOME/.local/bin/cursor-circle" off >/dev/null 2>&1 || true
  fi

  hyprctl keyword bind ", z, exec, $script_path click-toggle" >/dev/null
  hyprctl keyword bind ", plus, exec, $script_path speed-up 1" >/dev/null
  hyprctl keyword bind "CTRL, plus, exec, $script_path speed-up 10" >/dev/null
  hyprctl keyword bind "SHIFT, plus, exec, $script_path speed-up 100" >/dev/null
  hyprctl keyword bind ", minus, exec, $script_path speed-down 1" >/dev/null
  hyprctl keyword bind "CTRL, minus, exec, $script_path speed-down 10" >/dev/null
  hyprctl keyword bind "SHIFT, minus, exec, $script_path speed-down 100" >/dev/null
  : > "$armed_file"
  notify "z toggles clicking, +/- changes speed ($(read_speed)/s)"
}

disarm_z() {
  local notify_mode="${1:-always}"
  local was_clicking=0
  if is_clicking; then
    was_clicking=1
  fi

  stop_clicking
  hyprctl keyword unbind ", z" >/dev/null || true
  hyprctl keyword unbind ", plus" >/dev/null || true
  hyprctl keyword unbind "CTRL, plus" >/dev/null || true
  hyprctl keyword unbind "SHIFT, plus" >/dev/null || true
  hyprctl keyword unbind ", minus" >/dev/null || true
  hyprctl keyword unbind "CTRL, minus" >/dev/null || true
  hyprctl keyword unbind "SHIFT, minus" >/dev/null || true
  rm -f "$armed_file"

  if [[ "$notify_mode" == "always" || "$was_clicking" == "1" ]]; then
    notify "z is normal again"
  fi
}

speed_up() {
  local amount="${1:-1}"
  if [[ ! "$amount" =~ ^[0-9]+$ || "$amount" -lt 1 ]]; then
    amount="1"
  fi

  local speed
  speed="$(read_speed)"
  speed=$((speed + amount))
  write_speed "$speed"

  if is_clicking; then
    stop_clicking
    start_clicking
  fi

  notify "${speed} clicks/s"
}

speed_down() {
  local amount="${1:-1}"
  if [[ ! "$amount" =~ ^[0-9]+$ || "$amount" -lt 1 ]]; then
    amount="1"
  fi

  local speed
  speed="$(read_speed)"
  speed=$((speed - amount))
  if (( speed < 1 )); then
    speed=1
  fi
  write_speed "$speed"

  if is_clicking; then
    stop_clicking
    start_clicking
  fi

  notify "${speed} clicks/s"
}

case "${1:-}" in
  arm-toggle)
    if [[ -f "$armed_file" ]]; then
      disarm_z
    else
      arm_z
    fi
    ;;
  click-toggle)
    if is_clicking; then
      stop_clicking
      notify "clicking stopped"
    else
      start_clicking
      notify "clicking started"
    fi
    ;;
  off)
    disarm_z active
    ;;
  speed-up)
    speed_up "${2:-1}"
    ;;
  speed-down)
    speed_down "${2:-1}"
    ;;
  *)
    printf 'Usage: %s {arm-toggle|click-toggle|off|speed-up AMOUNT|speed-down AMOUNT}\n' "${0##*/}" >&2
    exit 2
    ;;
esac
