#!/usr/bin/env bash
set -euo pipefail

dotfiles_config="$HOME/.dotfiles/hypr/hyprland.conf"
if [[ -n "${HYPRLAND_CONFIG:-}" ]]; then
  config="$HYPRLAND_CONFIG"
elif [[ -f "$dotfiles_config" ]]; then
  config="$dotfiles_config"
else
  config="$HOME/.config/hypr/hyprland.conf"
fi

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
state_file="$cache_dir/custom-keybinds-sort"
used_file="$cache_dir/custom-keybinds-used"
details_file="$cache_dir/custom-keybinds-details"

mkdir -p "$cache_dir"

mode="added"
if [[ -f "$state_file" ]]; then
  IFS= read -r mode < "$state_file"
fi
if [[ "$mode" == "recent" ]]; then
  mode="used"
  printf '%s\n' "$mode" > "$state_file"
fi
if [[ "$mode" != "added" && "$mode" != "used" && "$mode" != "keybind" && "$mode" != "name" ]]; then
  mode="added"
fi

format_keybinds() {
  local source_file="${1:-$config}"
  awk '
    function trim(s) {
      gsub(/^[ \t]+|[ \t]+$/, "", s)
      return s
    }
    function pretty_mods(s) {
      s = trim(s)
      gsub(/SUPER/, "Leader", s)
      gsub(/SHIFT/, "Shift", s)
      gsub(/CTRL/, "Ctrl", s)
      gsub(/ALT/, "Alt", s)
      gsub(/[ \t]+/, "+", s)
      return s
    }
    function pretty_key(s) {
      s = trim(s)
      if (s == "RETURN") return "Enter"
      if (s == "SPACE") return "Space"
      if (s == "comma") return ","
      if (s == "Print") return "Print"
      return s
    }
    function title_from_comment(line) {
      if (match(line, /#[ \t]*(keybind|name|desc|description):[ \t]*/)) {
        title = substr(line, RSTART + RLENGTH)
        return trim(title)
      }
      return ""
    }
    function strip_keybind_comment(line) {
      sub(/[ \t]*#[ \t]*(keybind|name|desc|description):.*/, "", line)
      return line
    }
    function emit(mods, key, title, command) {
      mods = pretty_mods(mods)
      key = pretty_key(key)
      title = trim(title)
      command = trim(command)
      if (key ~ /^switch:/ || command == "true") return
      if (title == "" || title == "exec") title = "Unnamed"
      if (mods == "") {
        combo = key
      } else {
        combo = mods "+" key
      }
      display = sprintf("%-22s  %s", combo, title)
      printf "%s\t%s\t%s\n", display, command, combo
    }
    /^[ \t]*bindd[ \t]*=/ {
      line = $0
      line = strip_keybind_comment(line)
      sub(/^[ \t]*bindd[ \t]*=[ \t]*/, "", line)
      n = split(line, parts, ",")
      if (n >= 5) {
        command = trim(parts[4])
        for (i = 5; i <= n; i++) command = command ", " trim(parts[i])
        emit(parts[1], parts[2], parts[3], command)
      }
      next
    }
    /^[ \t]*bind(el|l)?[ \t]*=/ {
      line = $0
      override = title_from_comment(line)
      line = strip_keybind_comment(line)
      sub(/^[ \t]*bind(el|l)?[ \t]*=[ \t]*/, "", line)
      n = split(line, parts, ",")
      if (n >= 4) {
        title = override != "" ? override : trim(parts[3])
        command = trim(parts[4])
        for (i = 5; i <= n; i++) command = command ", " trim(parts[i])
        emit(parts[1], parts[2], title, command)
      }
    }
  ' "$source_file"
}

git_added_keybinds() {
  local repo_root config_rel tmp_history tmp_seen tmp_commit

  repo_root="$(git -C "$(dirname "$config")" rev-parse --show-toplevel 2>/dev/null || true)"
  [[ -n "$repo_root" ]] || return 1

  config_rel="$(realpath --relative-to="$repo_root" "$config" 2>/dev/null || true)"
  [[ -n "$config_rel" && -f "$repo_root/$config_rel" ]] || return 1

  tmp_history="$(mktemp)"
  tmp_seen="$(mktemp)"
  tmp_commit="$(mktemp)"

  cut -f3 "$details_file" | sort -u > "$tmp_seen"

  while IFS=: read -r commit_time commit_hash; do
    [[ -n "$commit_time" && -n "$commit_hash" ]] || continue
    if git -C "$repo_root" show "$commit_hash:$config_rel" > "$tmp_commit" 2>/dev/null; then
      format_keybinds "$tmp_commit" | cut -f3 | while IFS= read -r combo; do
        grep -Fxq "$combo" "$tmp_seen" || continue
        printf '%s\t%s\n' "$combo" "$commit_time"
      done
    fi
  done < <(git -C "$repo_root" log --reverse --format='%ct:%H' -- "$config_rel") > "$tmp_history"

  awk -F '\t' '
    NR == FNR {
      if (!first[$1]) first[$1] = $2
      next
    }
    {
      display = $1
      command = $2
      combo = $3
      score = first[combo] ? first[combo] : 9999999999
      printf "%s\t%s\n", score, display
    }
  ' "$tmp_history" "$details_file" | sort -rn | cut -f2-

  rm -f "$tmp_history" "$tmp_seen" "$tmp_commit"
}

ordered_keybinds() {
  format_keybinds > "$details_file"

  if [[ "$mode" == "added" ]]; then
    git_added_keybinds || cut -f1 "$details_file"
    return
  fi

  if [[ "$mode" == "keybind" ]]; then
    cut -f1 "$details_file" | sort -f
    return
  fi

  if [[ "$mode" == "name" ]]; then
    cut -f1 "$details_file" | sort -f -k2
    return
  fi

  tmp="$(mktemp)"
  cut -f1 "$details_file" > "$tmp"
  if [[ -f "$used_file" ]]; then
    awk 'NR==FNR { all[$0] = 1; next } all[$0] && !seen[$0]++ { print }' "$tmp" "$used_file"
  fi
  awk 'NR==FNR { used[$0] = 1; next } !used[$0] { print }' "$used_file" "$tmp" 2>/dev/null || cat "$tmp"
  rm -f "$tmp"
}

while true; do
  selection="$(
    {
      printf '%s\n' "Sort: added"
      printf '%s\n' "Sort: used"
      printf '%s\n' "Sort: keybind"
      printf '%s\n' "Sort: name"
      ordered_keybinds
    } | rofi -dmenu -i -p "Keybinds ($mode)"
  )"

  [[ -n "$selection" ]] || exit 0

  case "$selection" in
    "Sort: added")
      mode="added"
      printf '%s\n' "$mode" > "$state_file"
      continue
      ;;
    "Sort: used")
      mode="used"
      printf '%s\n' "$mode" > "$state_file"
      continue
      ;;
    "Sort: keybind")
      mode="keybind"
      printf '%s\n' "$mode" > "$state_file"
      continue
      ;;
    "Sort: name")
      mode="name"
      printf '%s\n' "$mode" > "$state_file"
      continue
      ;;
  esac

  {
    printf '%s\n' "$selection"
    [[ -f "$used_file" ]] && grep -Fvx -- "$selection" "$used_file" || true
  } > "$used_file.tmp"
  mv "$used_file.tmp" "$used_file"

  command="$(awk -F '\t' -v selected="$selection" '$1 == selected { print $2; exit }' "$details_file")"
  notify-send "Keybind" "$selection${command:+
$command}"
  exit 0
done
