#!/usr/bin/env bash
set -euo pipefail

dotfiles_config="$HOME/.dotfiles/hypr/hyprland.conf"
if [[ -n "${HYPRLAND_CONFIG:-}" ]]; then
  config="$HYPRLAND_CONFIG"
elif [[ -f "$dotfiles_config" ]]; then
  config="$dotfiles_config"
else
  config="$HOME/.config/hypr/hyprland.conf"
fi

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}"
state_file="$cache_dir/custom-keybinds-sort"
used_file="$cache_dir/custom-keybinds-used"
details_file="$cache_dir/custom-keybinds-details"
added_cache_file="$cache_dir/custom-keybinds-added-cache"
added_cache_meta="$cache_dir/custom-keybinds-added-cache-meta"

mkdir -p "$cache_dir"

rofi_args=()
rofi_args+=(-matching fuzzy)
if [[ "${ROFI_MENU_FULLSCREEN:-0}" == "1" ]]; then
  rofi_args+=(--fullscreen)
fi

mode="added"
if [[ -f "$state_file" ]]; then
  IFS= read -r mode < "$state_file"
fi
if [[ "$mode" == "recent" ]]; then
  mode="used"
  printf '%s\n' "$mode" > "$state_file"
fi
if [[ "$mode" != "added" && "$mode" != "used" && "$mode" != "keybind" && "$mode" != "name" ]]; then
  mode="added"
fi

next_sort_mode() {
  case "$1" in
    added) printf '%s\n' "used" ;;
    used) printf '%s\n' "keybind" ;;
    keybind) printf '%s\n' "name" ;;
    *) printf '%s\n' "added" ;;
  esac
}

format_keybinds() {
  local source_file="${1:-$config}"
  awk '
    function trim(s) {
      gsub(/^[ \t]+|[ \t]+$/, "", s)
      return s
    }
    function pretty_mods(s) {
      s = trim(s)
      gsub(/SUPER/, "Leader", s)
      gsub(/SHIFT/, "Shift", s)
      gsub(/CTRL/, "Ctrl", s)
      gsub(/ALT/, "Alt", s)
      gsub(/[ \t]+/, "+", s)
      return s
    }
    function pretty_key(s) {
      s = trim(s)
      if (s == "RETURN") return "Enter"
      if (s == "SPACE") return "Space"
      if (s == "comma") return ","
      if (s == "Print") return "Print"
      return s
    }
    function title_from_comment(line) {
      if (match(line, /#[ \t]*(keybind|name|desc|description):[ \t]*/)) {
        title = substr(line, RSTART + RLENGTH)
        return trim(title)
      }
      return ""
    }
    function strip_keybind_comment(line) {
      sub(/[ \t]*#[ \t]*(keybind|name|desc|description):.*/, "", line)
      return line
    }
    function emit(mods, key, title, command) {
      mods = pretty_mods(mods)
      key = pretty_key(key)
      title = trim(title)
      command = trim(command)
      if (key ~ /^switch:/ || command == "true") return
      if (title == "" || title == "exec") title = "Unnamed"
      if (mods == "") {
        combo = key
      } else {
        combo = mods "+" key
      }
      display = sprintf("%-22s  %s", combo, title)
      printf "%s\t%s\t%s\n", display, command, combo
    }
    /^[ \t]*bindd[ \t]*=/ {
      line = $0
      line = strip_keybind_comment(line)
      sub(/^[ \t]*bindd[ \t]*=[ \t]*/, "", line)
      n = split(line, parts, ",")
      if (n >= 5) {
        command = trim(parts[4])
        for (i = 5; i <= n; i++) command = command ", " trim(parts[i])
        emit(parts[1], parts[2], parts[3], command)
      }
      next
    }
    /^[ \t]*bind(el|l)?[ \t]*=/ {
      line = $0
      override = title_from_comment(line)
      line = strip_keybind_comment(line)
      sub(/^[ \t]*bind(el|l)?[ \t]*=[ \t]*/, "", line)
      n = split(line, parts, ",")
      if (n >= 4) {
        title = override != "" ? override : trim(parts[3])
        command = trim(parts[4])
        for (i = 5; i <= n; i++) command = command ", " trim(parts[i])
        emit(parts[1], parts[2], title, command)
      }
    }
  ' "$source_file"
}

write_added_cache_meta() {
  local repo_root="$1"
  local config_rel="$2"
  local head_hash="$3"

  {
    printf 'repo=%s\n' "$repo_root"
    printf 'config=%s\n' "$config_rel"
    printf 'head=%s\n' "$head_hash"
  } > "$added_cache_meta"
}

read_added_cache_head() {
  [[ -f "$added_cache_meta" ]] || return 1
  awk -F= '$1 == "head" { print $2; exit }' "$added_cache_meta"
}

update_added_cache_from_range() {
  local repo_root="$1"
  local config_rel="$2"
  local range="$3"
  local tmp_commit tmp_seen

  tmp_commit="$(mktemp)"
  tmp_seen="$(mktemp)"

  cut -f1 "$added_cache_file" 2>/dev/null | sort -u > "$tmp_seen"

  while IFS=: read -r commit_time commit_hash; do
    [[ -n "$commit_time" && -n "$commit_hash" ]] || continue
    if git -C "$repo_root" show "$commit_hash:$config_rel" > "$tmp_commit" 2>/dev/null; then
      format_keybinds "$tmp_commit" | cut -f3 | while IFS= read -r combo; do
        [[ -n "$combo" ]] || continue
        grep -Fxq "$combo" "$tmp_seen" && continue
        printf '%s\t%s\n' "$combo" "$commit_time" >> "$added_cache_file"
        printf '%s\n' "$combo" >> "$tmp_seen"
      done
    fi
  done < <(git -C "$repo_root" log --reverse --format='%ct:%H' "$range" -- "$config_rel")

  rm -f "$tmp_commit" "$tmp_seen"
}

refresh_added_cache() {
  local repo_root config_rel head_hash cached_head cached_repo cached_config

  repo_root="$(git -C "$(dirname "$config")" rev-parse --show-toplevel 2>/dev/null || true)"
  [[ -n "$repo_root" ]] || return 1

  config_rel="$(realpath --relative-to="$repo_root" "$config" 2>/dev/null || true)"
  [[ -n "$config_rel" && -f "$repo_root/$config_rel" ]] || return 1

  head_hash="$(git -C "$repo_root" rev-parse HEAD 2>/dev/null || true)"
  [[ -n "$head_hash" ]] || return 1

  cached_head="$(read_added_cache_head || true)"
  cached_repo="$(awk -F= '$1 == "repo" { print $2; exit }' "$added_cache_meta" 2>/dev/null || true)"
  cached_config="$(awk -F= '$1 == "config" { print $2; exit }' "$added_cache_meta" 2>/dev/null || true)"

  if [[ ! -s "$added_cache_file" || "$cached_repo" != "$repo_root" || "$cached_config" != "$config_rel" || -z "$cached_head" ]]; then
    : > "$added_cache_file"
    update_added_cache_from_range "$repo_root" "$config_rel" "HEAD"
    write_added_cache_meta "$repo_root" "$config_rel" "$head_hash"
    return
  fi

  if [[ "$cached_head" == "$head_hash" ]]; then
    return
  fi

  if git -C "$repo_root" merge-base --is-ancestor "$cached_head" "$head_hash" 2>/dev/null; then
    update_added_cache_from_range "$repo_root" "$config_rel" "$cached_head..HEAD"
  else
    : > "$added_cache_file"
    update_added_cache_from_range "$repo_root" "$config_rel" "HEAD"
  fi

  write_added_cache_meta "$repo_root" "$config_rel" "$head_hash"
}

git_added_keybinds() {
  refresh_added_cache || return 1

  awk -F '\t' '
    NR == FNR {
      if (!first[$1]) first[$1] = $2
      next
    }
    {
      display = $1
      command = $2
      combo = $3
      score = first[combo] ? first[combo] : 9999999999
      printf "%s\t%s\n", score, display
    }
  ' "$added_cache_file" "$details_file" | sort -rn | cut -f2-
}

ordered_keybinds() {
  local tmp

  format_keybinds > "$details_file"

  if [[ "$mode" == "added" ]]; then
    git_added_keybinds || cut -f1 "$details_file"
    return
  fi

  if [[ "$mode" == "keybind" ]]; then
    cut -f1 "$details_file" | sort -f
    return
  fi

  if [[ "$mode" == "name" ]]; then
    cut -f1 "$details_file" | sort -f -k2
    return
  fi

  tmp="$(mktemp)"
  cut -f1 "$details_file" > "$tmp"
  if [[ -f "$used_file" ]]; then
    awk 'NR==FNR { all[$0] = 1; next } all[$0] && !seen[$0]++ { print }' "$tmp" "$used_file"
  fi
  awk 'NR==FNR { used[$0] = 1; next } !used[$0] { print }' "$used_file" "$tmp" 2>/dev/null || cat "$tmp"
  rm -f "$tmp"
}

rofi_keybind_rows() {
  awk -F '\t' '
    NR == FNR {
      combo[$1] = $3
      next
    }
    {
      key = combo[$0]
      key_words = key
      key_compact = key
      gsub(/\+/, " ", key_words)
      gsub(/\+/, "", key_compact)
      meta = "key=" key " key=\"" key_words "\" key=" key_words " key=" key_compact
      printf "%s%cmeta%c%s\n", $0, 0, 31, meta
    }
  ' "$details_file" -
}

ordered_keybind_rows() {
  local tmp
  tmp="$(mktemp)"
  ordered_keybinds > "$tmp"
  rofi_keybind_rows < "$tmp"
  rm -f "$tmp"
}

while true; do
  next_mode="$(next_sort_mode "$mode")"
  selection="$(
    {
      printf 'Sort: %s (next: %s)\n' "$mode" "$next_mode"
      ordered_keybind_rows
    } | "$HOME/.local/bin/rofi-menu" "${rofi_args[@]}" -dmenu -i -p "Keybinds ($mode)"
  )"

  [[ -n "$selection" ]] || exit 0

  case "$selection" in
    Sort:*)
      mode="$next_mode"
      printf '%s\n' "$mode" > "$state_file"
      continue
      ;;
  esac

  {
    printf '%s\n' "$selection"
    [[ -f "$used_file" ]] && grep -Fvx -- "$selection" "$used_file" || true
  } > "$used_file.tmp"
  mv "$used_file.tmp" "$used_file"

  command="$(awk -F '\t' -v selected="$selection" '$1 == selected { print $2; exit }' "$details_file")"
  notify-send "Keybind" "$selection${command:+
$command}"
  exit 0
done
