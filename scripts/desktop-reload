#!/usr/bin/env bash
set -euo pipefail

notify() {
  notify-send "Desktop reload" "$1" -t 2500
}

failures=()

run_step() {
  local name="$1"
  shift

  if "$@"; then
    return 0
  fi

  failures+=("$name")
  return 0
}

run_step "systemd user daemon" systemctl --user daemon-reload
run_step "Wayland environment" systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP HYPRLAND_INSTANCE_SIGNATURE DISPLAY
run_step "Hyprland config" hyprctl reload
run_step "display mode" env DISPLAY_MENU_QUIET=1 /home/hjalte/.local/bin/display-menu apply-later
run_step "Waybar" systemctl --user restart waybar.service
run_step "clipboard history" systemctl --user restart cliphist-text.service cliphist-image.service

start_mako() {
  mako >/dev/null 2>&1 &
}

if pgrep -x mako >/dev/null 2>&1; then
  run_step "mako config" makoctl reload
else
  run_step "mako" start_mako
fi

if ((${#failures[@]})); then
  notify "Reloaded with issues: ${failures[*]}"
else
  notify "Hyprland, Waybar, mako, and clipboard history reloaded"
fi
