#!/usr/bin/env bash
set -euo pipefail

tmp_img="$(mktemp --suffix=.png)"
pix2tex_bin="${PIX2TEX_BIN:-pix2tex}"
log_file="${XDG_CACHE_HOME:-$HOME/.cache}/math-ocr.log"

cleanup() {
  rm -f "$tmp_img"
}
trap cleanup EXIT

debug_pix2tex() {
  printf 'Math OCR debug\n'
  printf '==============\n'
  printf 'pix2tex: %s\n' "$(command -v "$pix2tex_bin" || printf 'not found')"

  if command -v "$pix2tex_bin" >/dev/null 2>&1; then
    "$pix2tex_bin" --help | sed -n '1,30p'
  else
    printf 'Run your Home Manager switch so the Nix-managed pix2tex package is installed.\n'
  fi
}

case "${1:-run}" in
  debug)
    debug_pix2tex
    exit 0
    ;;
  run)
    ;;
  *)
    printf 'Usage: %s [run|debug]\n' "${0##*/}" >&2
    exit 2
    ;;
esac

if ! command -v "$pix2tex_bin" >/dev/null 2>&1; then
  notify-send -u critical "Math OCR" "pix2tex is not installed. Run your Home Manager switch." 2>/dev/null || true
  exit 1
fi

geometry="$(slurp)" || exit 1
grim -g "$geometry" "$tmp_img"

notify-send "Math OCR" "Processing equation..." -t 2000

mkdir -p "$(dirname "$log_file")"
if ! output="$("$pix2tex_bin" "$tmp_img" 2>"$log_file")"; then
  last_error="$(tail -n 3 "$log_file" | tr '\n' ' ' | cut -c 1-180)"
  notify-send -u critical "Math OCR failed" "${last_error:-See $log_file}"
  exit 1
fi

latex="$(printf '%s\n' "$output" | sed -E "s#^$tmp_img:[[:space:]]*##" | sed '/^[[:space:]]*$/d' | tail -n 1)"

if [[ -z "$latex" ]]; then
  notify-send -u critical "Math OCR" "No LaTeX output detected"
  exit 1
fi

printf '%s' "$latex" | wl-copy

notify-send "Math OCR" "LaTeX copied to clipboard!"
