#!/usr/bin/env bash
# shellcheck disable=SC2016
set -euo pipefail

inbox="${CODEX_CAPTURE_DIR:-$HOME/Documents/Codex-Inbox}"
timestamp="$(date +'%Y-%m-%d_%H-%M-%S')"

usage() {
  cat <<'EOF'
Usage:
  codex-capture
  codex-capture history [count]

Save the current clipboard into the Codex inbox, then replace the clipboard
with a ready-to-paste Codex prompt that points at the saved capture.

The history mode asks how many recent clipboard history entries to save, then
creates one prompt that points Codex at all saved files.
EOF
}

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$@"
  fi
}

archive_previous_active() {
  local active_dir old_dir

  active_dir="$inbox/ACTIVE"
  old_dir="$inbox/OLD_${timestamp}"

  if [[ -d "$active_dir" ]]; then
    mv "$active_dir" "$old_dir"
  fi
}

write_marker() {
  local saved="$1"
  local prompt="$2"

  {
    printf 'active=%s\n' "$saved"
    printf 'saved_at=%s\n' "$timestamp"
    printf 'prompt=%s\n' "$prompt"
    printf 'note=%s\n' "Read ACTIVE_* files only unless I ask for older context."
  } > "$inbox/ACTIVE_CONTEXT.txt"
}

write_multi_marker() {
  local prompt="$1"
  shift

  {
    printf 'active_files=%s\n' "$*"
    printf 'saved_at=%s\n' "$timestamp"
    printf 'prompt=%s\n' "$prompt"
    printf 'note=%s\n' "Read ACTIVE_* files only unless I ask for older context."
  } > "$inbox/ACTIVE_CONTEXT.txt"
}

save_text() {
  local output="$inbox/ACTIVE/capture.txt"
  local tmp

  tmp="$(mktemp "$inbox/.codex-capture.XXXXXX")"
  wl-paste --type text > "$tmp"

  if [[ ! -s "$tmp" ]]; then
    rm -f "$tmp"
    return 1
  fi

  archive_previous_active
  mkdir -p "$inbox/ACTIVE"
  mv "$tmp" "$output"
  printf '%s\n' "$output"
}

active_window_context() {
  local window_json workspace title class app initial_title pid address

  if ! command -v hyprctl >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
    printf 'Active window: unknown\n'
    return
  fi

  if ! window_json="$(hyprctl activewindow -j 2>/dev/null)" || [[ -z "$window_json" ]]; then
    printf 'Active window: unknown\n'
    return
  fi

  title="$(jq -r '.title // empty' <<<"$window_json")"
  initial_title="$(jq -r '.initialTitle // empty' <<<"$window_json")"
  class="$(jq -r '.class // empty' <<<"$window_json")"
  app="$(jq -r '.initialClass // empty' <<<"$window_json")"
  workspace="$(jq -r '.workspace.name // empty' <<<"$window_json")"
  pid="$(jq -r '.pid // empty' <<<"$window_json")"
  address="$(jq -r '.address // empty' <<<"$window_json")"

  printf 'Active window:\n'
  [[ -n "$title" ]] && printf -- '- title: %s\n' "$title"
  [[ -n "$class" ]] && printf -- '- class: %s\n' "$class"
  [[ -n "$app" && "$app" != "$class" ]] && printf -- '- initial_class: %s\n' "$app"
  [[ -n "$initial_title" && "$initial_title" != "$title" ]] && printf -- '- initial_title: %s\n' "$initial_title"
  [[ -n "$workspace" ]] && printf -- '- workspace: %s\n' "$workspace"
  [[ -n "$pid" && "$pid" != "0" ]] && printf -- '- pid: %s\n' "$pid"
  [[ -n "$address" ]] && printf -- '- address: %s\n' "$address"
}

write_prompt() {
  local saved="$1"
  local kind="$2"
  local size prompt="$inbox/ACTIVE/PROMPT.md"

  size="$(wc -c < "$saved" | tr -d '[:space:]')"

  {
    printf 'Please read this Codex clipboard capture and use it as context for my next request:\n\n'
    printf -- '- Capture file: `%s`\n' "$saved"
    printf -- '- Prompt file: `%s`\n' "$prompt"
    printf -- '- Clipboard kind: `%s`\n' "$kind"
    printf -- '- Captured at: `%s`\n' "$timestamp"
    printf -- '- Size: `%s bytes`\n\n' "$size"
    active_window_context
    printf '\nTask framing:\n'
    printf -- '- Treat the capture as copied from the active window above.\n'
    printf -- '- Infer the most likely source and purpose from the window metadata and content.\n'
    printf -- '- If the capture is code, quote only the relevant identifiers or short snippets and refer to the saved file path for the full content.\n'
    printf -- '- If something is ambiguous, state the assumption before acting.\n\n'
    printf 'Start by reading `%s`.\n' "$saved"
  } > "$prompt"

  write_marker "$saved" "$prompt"
  wl-copy < "$prompt"
  printf '%s\n' "$prompt"
}

write_multi_prompt() {
  local prompt="$inbox/ACTIVE/PROMPT.md"
  local file index size kind

  {
    printf 'Please read these Codex clipboard captures and use them as context for my next request:\n\n'
    printf -- '- Prompt file: `%s`\n' "$prompt"
    printf -- '- Captured at: `%s`\n' "$timestamp"
    printf -- '- Capture order: newest clipboard item first\n\n'
    printf 'Capture files:\n'

    index=1
    for file in "$@"; do
      size="$(wc -c < "$file" | tr -d '[:space:]')"
      kind="$(file --brief --mime-type "$file" 2>/dev/null || printf 'unknown')"
      printf '%s. `%s` (`%s`, `%s bytes`)\n' "$index" "$file" "$kind" "$size"
      index=$((index + 1))
    done

    printf '\n'
    active_window_context
    printf '\nTask framing:\n'
    printf -- '- Treat these captures as copied from the active window above and recent clipboard history.\n'
    printf -- '- Use the numbered order to reason about sequence when it matters.\n'
    printf -- '- If a capture is code or long text, quote only relevant identifiers or short snippets and refer to the saved file path for the full content.\n'
    printf -- '- If something is ambiguous, state the assumption before acting.\n\n'
    printf 'Start by reading the capture files listed above.\n'
  } > "$prompt"

  write_multi_marker "$prompt" "$@"
  wl-copy < "$prompt"
  printf '%s\n' "$prompt"
}

save_image() {
  local mime="$1"
  local ext="bin"
  local output tmp

  case "$mime" in
    image/png) ext="png" ;;
    image/jpeg) ext="jpg" ;;
    image/webp) ext="webp" ;;
    image/gif) ext="gif" ;;
    image/bmp) ext="bmp" ;;
    image/tiff) ext="tiff" ;;
  esac

  output="$inbox/ACTIVE/capture.${ext}"
  tmp="$(mktemp "$inbox/.codex-capture.XXXXXX")"
  wl-paste --type "$mime" > "$tmp"

  if [[ ! -s "$tmp" ]]; then
    rm -f "$tmp"
    return 1
  fi

  archive_previous_active
  mkdir -p "$inbox/ACTIVE"
  mv "$tmp" "$output"
  printf '%s\n' "$output"
}

history_count() {
  local requested="${1:-}"
  local choice
  local rofi_args=()

  if [[ -n "$requested" ]]; then
    if [[ "$requested" =~ ^[0-9]+$ ]] && ((requested > 0 && requested <= 50)); then
      printf '%s\n' "$requested"
      return 0
    fi

    notify "Codex capture skipped" "Enter a number from 1 to 50"
    return 1
  fi

  if [[ "${ROFI_MENU_FULLSCREEN:-0}" == "1" ]]; then
    rofi_args+=(--fullscreen)
  fi

  choice="$(
    printf '%s\n' 3 2 4 5 1 6 7 8 9 10 \
      | "$HOME/.local/bin/rofi-menu" "${rofi_args[@]}" -dmenu -p "Codex last N"
  )"

  [[ -n "$choice" ]] || return 1

  if [[ "$choice" =~ ^[0-9]+$ ]] && ((choice > 0 && choice <= 50)); then
    printf '%s\n' "$choice"
    return 0
  fi

  notify "Codex capture skipped" "Enter a number from 1 to 50"
  return 1
}

is_codex_generated_prompt() {
  local file="$1"

  LC_ALL=C rg -q \
    'Please read (this|these) Codex clipboard capture|Codex-Inbox/ACTIVE_|Capture file:|Capture files:' \
    "$file"
}

extension_for_mime() {
  case "$1" in
    image/png) printf 'png' ;;
    image/jpeg) printf 'jpg' ;;
    image/webp) printf 'webp' ;;
    image/gif) printf 'gif' ;;
    image/bmp) printf 'bmp' ;;
    image/tiff) printf 'tiff' ;;
    text/*|application/json|application/xml|application/x-shellscript|application/javascript) printf 'txt' ;;
    *) printf 'bin' ;;
  esac
}

capture_history() {
  local requested="${1:-}"
  local count history line tmp mime ext output index prompt staging_dir
  local staged_files=()
  local saved_files=()

  if ! command -v file >/dev/null 2>&1; then
    notify "Codex capture failed" "Missing file command"
    exit 1
  fi

  count="$(history_count "$requested")" || exit 0

  if ! history="$(cliphist list 2>/dev/null)" || [[ -z "$history" ]]; then
    notify "Codex capture failed" "No clipboard history yet"
    exit 1
  fi

  staging_dir="$(mktemp -d "$inbox/.codex-capture-history.XXXXXX")"

  index=1
  while IFS= read -r line; do
    [[ -n "$line" ]] || continue

    tmp="$(mktemp "$staging_dir/.codex-capture.XXXXXX")"
    if ! printf '%s' "$line" | cliphist decode > "$tmp" || [[ ! -s "$tmp" ]]; then
      rm -f "$tmp"
      continue
    fi

    if is_codex_generated_prompt "$tmp"; then
      rm -f "$tmp"
      continue
    fi

    mime="$(file --brief --mime-type "$tmp" 2>/dev/null || printf 'application/octet-stream')"
    ext="$(extension_for_mime "$mime")"
    output="$staging_dir/$(printf '%02d' "$index").$ext"
    mv "$tmp" "$output"
    staged_files+=("$output")
    index=$((index + 1))
    ((index > count)) && break
  done < <(printf '%s\n' "$history")

  if ((${#staged_files[@]} == 0)); then
    rm -rf "$staging_dir"
    notify "Codex capture failed" "Could not find usable clipboard history"
    exit 1
  fi

  archive_previous_active
  mkdir -p "$inbox/ACTIVE"

  for tmp in "${staged_files[@]}"; do
    output="$inbox/ACTIVE/$(basename "$tmp")"
    mv "$tmp" "$output"
    saved_files+=("$output")
  done
  rmdir "$staging_dir"

  prompt="$(write_multi_prompt "${saved_files[@]}")"
  notify "Codex prompt copied" "$prompt"
}

main() {
  local types mime saved prompt

  mkdir -p "$inbox"

  case "${1:-}" in
    -h|--help)
      usage
      exit 0
      ;;
    history)
      capture_history "${2:-}"
      exit 0
      ;;
    "")
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac

  if ! types="$(wl-paste --list-types 2>/dev/null)"; then
    notify "Codex capture failed" "Could not read clipboard"
    exit 1
  fi

  if printf '%s\n' "$types" | rg -q '^(text/plain|text/plain;charset=utf-8|UTF8_STRING)$'; then
    saved="$(save_text)"
    prompt="$(write_prompt "$saved" "text")"
    notify "Codex prompt copied" "$prompt"
    exit 0
  fi

  mime="$(printf '%s\n' "$types" | rg '^image/(png|jpeg|webp|gif|bmp|tiff)$' | head -n 1 || true)"
  if [[ -n "$mime" ]]; then
    saved="$(save_image "$mime")"
    prompt="$(write_prompt "$saved" "$mime")"
    notify "Codex prompt copied" "$prompt"
    exit 0
  fi

  notify "Codex capture skipped" "Clipboard is not text or a supported image"
  printf 'Clipboard is not text or a supported image.\n' >&2
  exit 1
}

main "$@"
