
# Font
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
font-size = 16

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 14
confirm-close-surface=false
resize-overlay = never
gtk-toolbar-style = flat

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Trying to fix ghostty crash
gtk-single-instance = true 
window-decoration = false

# Clipboard shortcuts. Ctrl+C only copies when text is selected; otherwise it
# still reaches the shell as interrupt.
keybind = performable:ctrl+c=copy_to_clipboard:mixed
keybind = ctrl+v=paste_from_clipboard
