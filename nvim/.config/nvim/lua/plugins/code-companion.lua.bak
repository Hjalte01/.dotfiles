-- ~/.config/nvim/lua/plugins/code-companion.lua

return {
  "olimorris/codecompanion.nvim",
  dependencies = {
    "nvim-lua/plenary.nvim",
    "nvim-treesitter/nvim-treesitter",
    "ravitemer/mcphub.nvim",
  },
  config = function()
    require("codecompanion").setup({
      adapters = {
        openrouter = function()
          return require("codecompanion.adapters").extend("openai", {
            name = "openrouter", -- Name MUST match the table key perfectly
            url = "https://openrouter.ai/api/v1/chat/completions",
            env = {
              -- The 'cmd:' prefix tells it to read the file safely
              api_key = "cmd:cat /home/hjalte/.openrouter_api_key",
            },
            schema = {
              model = {
                default = "inclusionai/ling-2.6-flash:free",
              },
            },
          })
        end,
      },
      strategies = {
        chat = {
          adapter = "openrouter",
          tools = {
            ["mcp"] = {
              callback = function()
                return require("mcphub.extensions.codecompanion")
              end,
            },
          },
        },
        inline = { adapter = "openrouter" },
      },
    })
  end,
  keys = {
    { "<leader>a", "<cmd>CodeCompanionChat Toggle<cr>", mode = { "n", "v" }, desc = "Toggle AI Chat" },
  },
}
